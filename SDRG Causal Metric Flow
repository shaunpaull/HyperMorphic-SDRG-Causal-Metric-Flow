def run_single_seed(seed=0, T=1400, warmup=80, k=12):
    x, regimes = make_sdrg_sequence(seed=seed, T=T)
    F = build_causal_features(x)
    Y = x[1:]

    Fz, mu, sigma = standardize(F)
    D = Fz.shape[1]

    baselines = {
        "position_euclidean": np.array([1, 1] + [0] * (D - 2), dtype=float),

        "fixed_augmented": np.ones(D, dtype=float),

        "fixed_velocity": np.array([
            0.5, 0.5,
            4.0, 4.0,
            0.2, 0.2,
            2.0,
            0.2,
            0.2,
            0.2,
            1.0, 1.0,
        ], dtype=float),

        "fixed_curvature": np.array([
            0.4, 0.4,
            1.0, 1.0,
            2.0, 2.0,
            0.5,
            1.0,
            4.0,
            3.0,
            2.0, 2.0,
        ], dtype=float),
    }

    errors = {name: [] for name in baselines}

    sdrg = SDRGCausalMetricFlow(feature_dim=D, k=k)

    sdrg_errors = []
    weight_trace = []
    active_chart_trace = []
    metric_volume_trace = []

    for t in range(warmup, len(Y) - 1):
        # Update the geometry from previous causal prediction regret.
        sdrg.update_from_previous(Fz, Y, t)

        # Fixed-geometry baselines.
        for name, diag in baselines.items():
            pred = knn_predict_metric(Fz, Y, t, diag, k=k, warmup=warmup)
            errors[name].append(mse(pred, Y[t]))

        # SDRG state-dependent metric flow.
        pred, chart_preds, q = sdrg.predict(Fz, Y, t)
        sdrg_errors.append(mse(pred, Y[t]))

        G, _ = sdrg.current_metric(Fz[t])
        metric_volume = float(np.exp(np.mean(np.log(G + 1e-9))))

        weight_trace.append(q)
        active_chart_trace.append(int(np.argmax(q)))
        metric_volume_trace.append(metric_volume)

    summary = {name: float(np.mean(vals)) for name, vals in errors.items()}
    summary["SDRG_causal_metric_flow"] = float(np.mean(sdrg_errors))

    best_fixed = min(
        summary[name]
        for name in summary
        if name != "SDRG_causal_metric_flow"
    )

    summary["best_fixed"] = float(best_fixed)
    summary["SDRG_improvement_vs_best_fixed_pct"] = improvement_pct(
        best_fixed,
        summary["SDRG_causal_metric_flow"],
    )

    return {
        "seed": seed,
        "summary": summary,
        "weight_trace": np.array(weight_trace),
        "active_chart_trace": np.array(active_chart_trace),
        "metric_volume_trace": np.array(metric_volume_trace),
        "chart_names": [c.name for c in sdrg.charts],
        "trajectory": x,
        "regimes": regimes,
    }


def run_benchmark(seeds=(0, 1, 2, 3, 4), T=1400, warmup=80):
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG Causal Metric Flow Benchmark                                  ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")

    runs = []

    for seed in seeds:
        result = run_single_seed(seed=seed, T=T, warmup=warmup)
        runs.append(result)

        s = result["summary"]
        print()
        print(f"Seed {seed}")
        print("─" * 72)
        for key, value in s.items():
            if key.endswith("_pct"):
                print(f"  {key:<38} {value:>10.2f}%")
            else:
                print(f"  {key:<38} {value:>10.6f}")

    model_names = [
        "position_euclidean",
        "fixed_augmented",
        "fixed_velocity",
        "fixed_curvature",
        "SDRG_causal_metric_flow",
    ]

    aggregate = {}

    for name in model_names:
        vals = [r["summary"][name] for r in runs]
        aggregate[name] = {
            "mean": float(np.mean(vals)),
            "std": float(np.std(vals)),
        }

    improvements = [
        r["summary"]["SDRG_improvement_vs_best_fixed_pct"]
        for r in runs
    ]

    aggregate["SDRG_improvement_vs_best_fixed_pct"] = {
        "mean": float(np.mean(improvements)),
        "std": float(np.std(improvements)),
    }

    print()
    print("════════════════════════════════════════════════════════════════════════")
    print("AGGREGATE RESULTS")
    print("════════════════════════════════════════════════════════════════════════")

    for name in model_names:
        print(
            f"  {name:<32} "
            f"MSE={aggregate[name]['mean']:.6f} ± {aggregate[name]['std']:.6f}"
        )

    print(
        f"\n  SDRG improvement vs best fixed: "
        f"{aggregate['SDRG_improvement_vs_best_fixed_pct']['mean']:.2f}% "
        f"± {aggregate['SDRG_improvement_vs_best_fixed_pct']['std']:.2f}%"
    )

    return runs, aggregate


