def rotation(theta, scale=0.985):
    c, s = np.cos(theta), np.sin(theta)
    return scale * np.array([[c, -s], [s, c]])


def make_sdrg_sequence(seed=0, T=1400, noise=0.025):
    """
    Generate a regime-switching dynamical system.

    Hidden regimes overlap in position space, so fixed Euclidean geometry
    often confuses states that look positionally similar but have different
    causal futures.

    The correct geometry depends on causal history:
      - position
      - velocity
      - acceleration
      - curvature
      - phase
      - local energy
    """
    rng = np.random.default_rng(seed)

    regimes = []
    t = 0
    r = int(rng.integers(0, 4))

    while t < T + 2:
        duration = int(rng.integers(35, 95))
        r = int((r + rng.choice([1, 2, 3])) % 4)
        regimes += [r] * duration
        t += duration

    regimes = np.array(regimes[:T + 2])

    A = [
        rotation(+0.25),
        rotation(-0.25),
        np.array([[1.020, 0.080], [0.000, 0.940]]),
        np.array([[0.940, 0.000], [-0.080, 1.020]]),
    ]

    x = np.zeros((T + 2, 2))
    x[0] = rng.normal(size=2) * 0.50
    x[1] = x[0] + rng.normal(size=2) * 0.10

    for i in range(1, T + 1):
        regime = regimes[i]
        prev = x[i]
        vel = x[i] - x[i - 1]

        if regime == 0:
            nxt = A[regime] @ prev + 0.22 * np.tanh(np.array([vel[1], -vel[0]]))
        elif regime == 1:
            nxt = A[regime] @ prev + 0.22 * np.tanh(np.array([-vel[1], vel[0]]))
        elif regime == 2:
            nxt = A[regime] @ prev + 0.12 * np.array([
                np.sin(2 * prev[1]),
                np.cos(prev[0]),
            ])
        else:
            nxt = A[regime] @ prev + 0.12 * np.array([
                np.cos(prev[1]),
                -np.sin(2 * prev[0]),
            ])

        nxt += noise * rng.normal(size=2)

        # Keep the system bounded.
        norm = np.linalg.norm(nxt)
        if norm > 3.5:
            nxt = nxt / norm * 3.5

        x[i + 1] = nxt

    return x[:T + 1], regimes[:T + 1]


def build_causal_features(x):
    """
    z_t is a causal representation computed from history through time t.

    Features:
      0,1   position
      2,3   velocity
      4,5   acceleration
      6     speed
      7     acceleration magnitude
      8     curvature-like cross(v,a)
      9     alignment dot(v,a)
      10    sin phase
      11    cos phase
    """
    T = len(x) - 1
    F = np.zeros((T, 12), dtype=float)

    for t in range(T):
        pos = x[t]

        v = x[t] - x[t - 1] if t >= 1 else np.zeros(2)
        v_prev = x[t - 1] - x[t - 2] if t >= 2 else np.zeros(2)
        a = v - v_prev

        speed = np.linalg.norm(v)
        acc = np.linalg.norm(a)

        cross = v[0] * a[1] - v[1] * a[0]
        dot = float(v @ a)

        angle = np.arctan2(v[1], v[0]) if speed > 1e-9 else 0.0

        F[t] = [
            pos[0], pos[1],
            v[0], v[1],
            a[0], a[1],
            speed,
            acc,
            cross,
            dot,
            np.sin(angle),
            np.cos(angle),
        ]

    return F


def standardize(F):
    mu = F.mean(axis=0)
    sigma = F.std(axis=0) + 1e-6
    return (F - mu) / sigma, mu, sigma


