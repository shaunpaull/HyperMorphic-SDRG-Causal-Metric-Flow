# SECTION 3 — METRIC KNN ENGINE
# ═══════════════════════════════════════════════════════════════════════

def knn_predict_metric(F, Y, t, diag_metric, k=12, warmup=80):
    """
    One-step prediction using a diagonal Mahalanobis metric.

    d_t(i)^2 = (F_i - F_t)^T G (F_i - F_t)
    """
    if t <= warmup:
        if t == 0:
            return np.zeros(Y.shape[1])
        return Y[:t].mean(axis=0)

    Xpast = F[:t]
    diff = Xpast - F[t]
    d2 = np.sum((diff * diff) * diag_metric, axis=1)

    k_eff = min(k, len(d2))
    idx = np.argpartition(d2, k_eff - 1)[:k_eff]

    dd = d2[idx]
    w = 1.0 / (1e-6 + dd)

    return np.sum(Y[idx] * w[:, None], axis=0) / np.sum(w)


