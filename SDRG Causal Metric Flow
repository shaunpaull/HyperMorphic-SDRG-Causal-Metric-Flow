def run_tests():
    print("\n╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG Causal Metric Flow — Tests                                    ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")

    results = []

    def check(name, ok, note=""):
        results.append(bool(ok))
        icon = "✅" if ok else "❌"
        print(f"  {icon} {name:<65} {note}")

    x, regimes = make_sdrg_sequence(seed=123, T=300)
    F = build_causal_features(x)
    Fz, _, _ = standardize(F)
    Y = x[1:]

    sdrg = SDRGCausalMetricFlow(feature_dim=Fz.shape[1])

    G, q = sdrg.current_metric(Fz[100])

    check("Feature matrix has expected shape", F.shape[1] == 12, str(F.shape))
    check("Metric weights sum to one", abs(np.sum(q) - 1.0) < 1e-9, f"sum={np.sum(q)}")
    check("Metric entries are positive", np.all(G > 0), f"min={G.min():.4f}")
    check("Chart count is six", len(sdrg.charts) == 6, f"charts={len(sdrg.charts)}")

    pred, chart_preds, q = sdrg.predict(Fz, Y, 100)

    check("Prediction is 2D", pred.shape == (2,), str(pred.shape))
    check("Chart predictions shape is valid", chart_preds.shape == (6, 2), str(chart_preds.shape))

    old_loss = sdrg.loss.copy()
    sdrg.update_from_previous(Fz, Y, 101)

    check("Online regret update changes chart loss", np.linalg.norm(sdrg.loss - old_loss) > 0)

    # Mini benchmark sanity.
    r = run_single_seed(seed=999, T=500, warmup=60)
    s = r["summary"]

    check("Benchmark returns SDRG result", "SDRG_causal_metric_flow" in s)
    check("Improvement value is finite", np.isfinite(s["SDRG_improvement_vs_best_fixed_pct"]))

    passed = sum(results)
    total = len(results)

    print("\n" + "═" * 72)
    print(f"  TESTS: {passed}/{total} passed")
    print("═" * 72)

    if passed == total:
        print("  ✅ ALL TESTS PASSED")
    else:
        print(f"  ❌ {total - passed} TESTS FAILED")

    return passed == total


