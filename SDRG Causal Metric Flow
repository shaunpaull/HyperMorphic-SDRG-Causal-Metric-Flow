@dataclass
class MetricChart:
    name: str
    diag: np.ndarray


class SDRGCausalMetricFlow:
    """
    State-Dependent Representation Geometry primitive.

    A finite metric atlas {G_c} is routed by a causal state H_t.

    Router:
        q_t = softmax(-η R_t + π(z_t))

    where:
        R_t = online EMA regret/loss of each chart
        π(z_t) = causal state prior from speed/acceleration/curvature/phase

    Metric:
        G_t = Σ_c q_c(t) G_c

    Predictor:
        chart-wise metric KNN predictions are mixed by q_t.
    """

    def __init__(
        self,
        feature_dim=12,
        k=12,
        eta=4.0,
        alpha=0.04,
    ):
        self.feature_dim = feature_dim
        self.k = k
        self.eta = eta
        self.alpha = alpha

        self.charts = self._build_charts(feature_dim)
        self.loss = np.ones(len(self.charts), dtype=float)
        self.last_weights = np.ones(len(self.charts)) / len(self.charts)

    def _build_charts(self, D):
        base = np.ones(D) * 0.15
        charts = []

        def make(name, weights):
            v = base.copy()
            for idx, value in weights.items():
                v[idx] = value
            charts.append(MetricChart(name, v))

        make("position", {
            0: 3.0, 1: 3.0,
            2: 0.2, 3: 0.2,
        })

        make("velocity", {
            0: 0.6, 1: 0.6,
            2: 4.0, 3: 4.0,
            6: 2.0,
            10: 1.0, 11: 1.0,
        })

        make("acceleration", {
            2: 0.8, 3: 0.8,
            4: 4.0, 5: 4.0,
            7: 3.0,
            8: 2.0, 9: 2.0,
        })

        make("curvature", {
            2: 1.0, 3: 1.0,
            8: 5.0,
            9: 3.0,
            10: 2.0, 11: 2.0,
        })

        make("phase_energy", {
            0: 0.8, 1: 0.8,
            6: 3.0,
            7: 2.0,
            10: 4.0, 11: 4.0,
        })

        make("balanced", {i: 1.0 for i in range(D)})

        return charts

    def causal_prior_logits(self, z):
        """
        Deterministic causal prior over charts from current state.

        The prior is not using the hidden regime. It only sees causal features.
        """
        speed = abs(z[6])
        accel = abs(z[7])
        curvature = abs(z[8]) + 0.5 * abs(z[9])
        phase = abs(z[10]) + abs(z[11])

        return np.array([
            0.40 - 0.10 * speed - 0.10 * accel,
            0.50 * speed,
            0.55 * accel,
            0.45 * curvature,
            0.25 * phase + 0.15 * speed,
            0.10,
        ])

    def weights(self, z):
        logits = -self.eta * self.loss + self.causal_prior_logits(z)
        q = softmax(logits)
        self.last_weights = q
        return q

    def current_metric(self, z):
        q = self.weights(z)
        G = np.zeros(self.feature_dim)

        for weight, chart in zip(q, self.charts):
            G += weight * chart.diag

        return G, q

    def predict(self, F, Y, t):
        q = self.weights(F[t])
        chart_preds = []

        for chart in self.charts:
            pred = knn_predict_metric(F, Y, t, chart.diag, k=self.k)
            chart_preds.append(pred)

        chart_preds = np.array(chart_preds)
        pred = np.sum(chart_preds * q[:, None], axis=0)

        return pred, chart_preds, q

    def update_from_previous(self, F, Y, t):
        """
        Online causal regret update.

        At time t, Y[t-1] is known, so update chart losses based on
        how each chart predicted the previous transition.
        """
        if t < 3:
            return

        prev = t - 1
        errors = []

        for chart in self.charts:
            pred = knn_predict_metric(F, Y, prev, chart.diag, k=self.k)
            errors.append(mse(pred, Y[prev]))

        errors = np.array(errors)
        self.loss = (1.0 - self.alpha) * self.loss + self.alpha * errors


