if TORCH_AVAILABLE:
    class SeqRegressor(nn.Module):
        def __init__(self, kind, input_dim=1, hidden=48, layers=1, heads=4, transformer_layers=1):
            super().__init__()
            self.kind = kind
            self.hidden = hidden
            if kind == "RNN":
                self.seq = nn.RNN(input_dim, hidden, layers, batch_first=True)
                self.head = nn.Linear(hidden, 1)
            elif kind == "GRU":
                self.seq = nn.GRU(input_dim, hidden, layers, batch_first=True)
                self.head = nn.Linear(hidden, 1)
            elif kind == "LSTM":
                self.seq = nn.LSTM(input_dim, hidden, layers, batch_first=True)
                self.head = nn.Linear(hidden, 1)
            elif kind == "Transformer":
                self.proj = nn.Linear(input_dim, hidden)
                enc_layer = nn.TransformerEncoderLayer(
                    d_model=hidden, nhead=heads, dim_feedforward=hidden*2,
                    batch_first=True, dropout=0.05
                )
                self.encoder = nn.TransformerEncoder(enc_layer, num_layers=transformer_layers)
                self.pos = nn.Parameter(torch.randn(1, 512, hidden) * 0.01)
                self.head = nn.Linear(hidden, 1)
            else:
                raise ValueError(kind)

        def forward(self, x):
            if self.kind in ("RNN", "GRU", "LSTM"):
                out, _ = self.seq(x)
                return self.head(out[:, -1, :])
            h = self.proj(x)
            h = h + self.pos[:, :h.shape[1], :]
            out = self.encoder(h)
            return self.head(out[:, -1, :])

def train_torch_model(kind, Xtr, ytr, Xval, yval, Xte, cfg):
    if not TORCH_AVAILABLE:
        return None

    device = "cuda" if torch.cuda.is_available() else "cpu"
    set_seed(cfg.seed + hash(kind) % 10000)

    model = SeqRegressor(
        kind,
        input_dim=Xtr.shape[-1],
        hidden=cfg.torch_hidden,
        layers=cfg.torch_layers,
        heads=cfg.transformer_heads,
        transformer_layers=cfg.transformer_layers,
    ).to(device)

    opt = torch.optim.AdamW(model.parameters(), lr=cfg.torch_lr, weight_decay=1e-4)
    loss_fn = nn.MSELoss()

    Xtr_t = torch.tensor(Xtr, dtype=torch.float32)
    ytr_t = torch.tensor(ytr, dtype=torch.float32)
    Xval_t = torch.tensor(Xval, dtype=torch.float32).to(device)
    yval_t = torch.tensor(yval, dtype=torch.float32).to(device)
    Xte_t = torch.tensor(Xte, dtype=torch.float32).to(device)

    loader = DataLoader(TensorDataset(Xtr_t, ytr_t), batch_size=cfg.torch_batch_size, shuffle=True)

    best_state, best_val = None, float("inf")
    patience, bad = 5, 0

    for ep in range(cfg.torch_epochs):
        model.train()
        for xb, yb in loader:
            xb, yb = xb.to(device), yb.to(device)
            opt.zero_grad()
            loss = loss_fn(model(xb), yb)
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()

        model.eval()
        with torch.no_grad():
            val_loss = float(loss_fn(model(Xval_t), yval_t).item())
        if val_loss < best_val:
            best_val = val_loss
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
            bad = 0
        else:
            bad += 1
            if bad >= patience:
                break

    if best_state is not None:
        model.load_state_dict(best_state)
    model.eval()
    with torch.no_grad():
        preds = model(Xte_t).cpu().numpy()
    return preds


