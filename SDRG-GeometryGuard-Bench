def clean_series(x):
    x = pd.Series(np.asarray(x, dtype=float)).replace([np.inf, -np.inf], np.nan)
    x = x.interpolate(limit_direction="both").ffill().bfill()
    return x.values.astype(float)

def load_realworld_series() -> Dict[str, np.ndarray]:
    """
    Load real-world univariate or selected target series.
    Uses statsmodels built-in datasets to avoid fragile external downloads.
    """
    datasets = {}

    if STATSMODELS_AVAILABLE:
        try:
            co2 = sm.datasets.co2.load_pandas().data["co2"]
            co2 = co2.interpolate(limit_direction="both").ffill().bfill()
            datasets["mauna_loa_co2"] = clean_series(co2.values)
        except Exception as e:
            print("Could not load CO2:", e)

        try:
            sun = sm.datasets.sunspots.load_pandas().data["SUNACTIVITY"]
            datasets["sunspots"] = clean_series(sun.values)
        except Exception as e:
            print("Could not load sunspots:", e)

        try:
            nile = sm.datasets.nile.load_pandas().data["volume"]
            datasets["nile"] = clean_series(nile.values)
        except Exception as e:
            print("Could not load nile:", e)

        try:
            macro = sm.datasets.macrodata.load_pandas().data
            # Real GDP quarterly series.
            datasets["us_realgdp"] = clean_series(macro["realgdp"].values)
            datasets["us_inflation"] = clean_series(macro["infl"].values)
        except Exception as e:
            print("Could not load macrodata:", e)

    if not datasets:
        # Last-resort real data from a tiny embedded sunspot-like public-domain snippet would be inappropriate.
        # Instead fail loudly.
        raise RuntimeError("No real-world datasets available. Install statsmodels or add a CSV loader.")

    return datasets


