def make_plots(results, paired, cfg):
    out = cfg.out_dir
    os.makedirs(out, exist_ok=True)

    # Per dataset leaderboard.
    for ds in sorted(results.dataset.unique()):
        sub = results[results.dataset == ds].sort_values("mse")
        plt.figure(figsize=(11,5))
        plt.bar(range(len(sub)), sub["mse"].values)
        plt.xticks(range(len(sub)), sub["model"].values, rotation=35, ha="right")
        plt.ylabel("Test MSE")
        plt.title(f"Real-world leaderboard: {ds}")
        plt.tight_layout()
        plt.savefig(os.path.join(out, f"leaderboard_{ds}.png"), dpi=180)
        plt.close()

    plt.figure(figsize=(10,4))
    colors = ["tab:green" if x else "tab:red" for x in paired["sdrg_win"]]
    plt.bar(paired["dataset"], paired["relative_gain_pct"], color=colors)
    plt.axhline(0, color="black", linewidth=1)
    plt.xticks(rotation=30, ha="right")
    plt.ylabel("SDRG gain vs best non-SDRG baseline (%)")
    plt.title("GeometryGuard vs best fixed/neural baseline")
    plt.tight_layout()
    plt.savefig(os.path.join(out, "sdrg_vs_best_non_sdrg_gain.png"), dpi=180)
    plt.close()

def write_results_card(results, paired, cfg):
    out = cfg.out_dir
    with open(os.path.join(out, "RESULTS_CARD.md"), "w") as f:
        f.write("# SDRG GeometryGuard Real-World Benchmark\n\n")
        f.write("Compared SDRG GeometryGuard against fixed metric baselines and PyTorch RNN/GRU/LSTM/Transformer baselines on statsmodels real-world time series.\n\n")
        f.write("## Paired summary\n\n")
        f.write(paired.to_markdown(index=False))
        f.write("\n\n## Claim discipline\n\n")
        f.write("- Allowed: controlled real-world time-series comparison under chronological train/val/test splits.\n")
        f.write("- Not claimed: SOTA forecasting, transformer superiority, production readiness, or universal SDRG superiority.\n")
        f.write("\n\n## Notes\n\n")
        f.write("GeometryGuard is evaluated as an online prequential memory model on the test segment, updating only after each true test target is observed. Neural baselines are trained on train and selected by validation unless online fine-tuning is explicitly enabled.\n")

def save_artifacts(results, paired, cfg):
    out = cfg.out_dir
    os.makedirs(out, exist_ok=True)
    results.to_csv(os.path.join(out, "realworld_model_results.csv"), index=False)
    paired.to_csv(os.path.join(out, "paired_sdrg_vs_best_non_sdrg.csv"), index=False)

    report = {
        "config": asdict(cfg),
        "environment": {
            "python": sys.version,
            "platform": platform.platform(),
            "numpy": np.__version__,
            "pandas": pd.__version__,
            "torch_available": TORCH_AVAILABLE,
            "statsmodels_available": STATSMODELS_AVAILABLE,
            "scipy_available": SCIPY_AVAILABLE,
        },
        "paired_summary": paired.to_dict(orient="records"),
        "claim_discipline": {
            "allowed": [
                "real-world chronological benchmark against fixed metric and neural sequence baselines",
                "GeometryGuard evaluated as online prequential metric-memory model",
            ],
            "not_claimed": [
                "SOTA forecasting",
                "beats all transformers",
                "production readiness",
                "universal superiority",
            ],
        },
    }
    with open(os.path.join(out, "benchmark_report.json"), "w") as f:
        json.dump(report, f, indent=2)

    write_results_card(results, paired, cfg)

    zpath = os.path.join(out, "sdrg_geometryguard_realworld_artifacts.zip")
    with zipfile.ZipFile(zpath, "w", zipfile.ZIP_DEFLATED) as z:
        for root, _, files in os.walk(out):
            for file in files:
                if file.endswith(".zip"):
                    continue
                full = os.path.join(root, file)
                z.write(full, arcname=os.path.relpath(full, out))
    return zpath


