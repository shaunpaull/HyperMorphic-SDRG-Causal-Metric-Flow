def run_benchmark(cfg):
    set_seed(cfg.seed)
    os.makedirs(cfg.out_dir, exist_ok=True)

    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG GeometryGuard Real-World Benchmark                           ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")
    print(json.dumps(asdict(cfg), indent=2))

    if not run_tests(cfg):
        raise RuntimeError("Acceptance tests failed.")

    datasets = load_realworld_series()
    if cfg.quick:
        datasets = dict(list(datasets.items())[:cfg.max_datasets_quick])

    all_results = []
    for name, series in datasets.items():
        print(f"\n=== Dataset: {name} | n={len(series)} ===")
        df = run_dataset(name, series, cfg)
        print(df.sort_values("mse").to_string(index=False))
