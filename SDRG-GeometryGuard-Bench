def set_seed(seed: int):
    random.seed(seed)
    np.random.seed(seed)
    if TORCH_AVAILABLE:
        torch.manual_seed(seed)
        torch.cuda.manual_seed_all(seed)
        torch.backends.cudnn.deterministic = True
        torch.backends.cudnn.benchmark = False

def mse(yhat, y):
    yhat, y = np.asarray(yhat), np.asarray(y)
    return float(np.mean((yhat - y) ** 2))

def mae(yhat, y):
    yhat, y = np.asarray(yhat), np.asarray(y)
    return float(np.mean(np.abs(yhat - y)))

def rmse(v):
    return float(np.sqrt(max(0.0, v)))

def softmax(x):
    z = np.asarray(x, dtype=float)
    z -= z.max()
    e = np.exp(z)
    return e / e.sum()

def bootstrap_ci(vals, n=1000, seed=123):
    vals = np.asarray(vals, dtype=float)
    if len(vals) == 0:
        return [None, None]
    rng = np.random.default_rng(seed)
    out = [float(np.mean(rng.choice(vals, size=len(vals), replace=True))) for _ in range(n)]
    return [float(np.percentile(out, 2.5)), float(np.percentile(out, 97.5))]


class TrainScaler:
    """Leak-safe scaler fit only on training split."""
    def fit(self, X):
        self.fit_n_ = len(X)
        self.mu = np.nanmean(X, axis=0)
        self.sigma = np.nanstd(X, axis=0) + 1e-8
        return self
    def transform(self, X):
        return (X - self.mu) / self.sigma
    def inverse_y(self, y_scaled, y_index=0):
        return y_scaled * self.sigma[y_index] + self.mu[y_index]


