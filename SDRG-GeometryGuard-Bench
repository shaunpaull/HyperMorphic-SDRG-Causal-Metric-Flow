def evaluate_geometryguard(F, Y, train_idx, val_idx, test_idx, cfg, seq_len):
    scaler = TrainScaler().fit(F[train_idx])
    Fs = scaler.transform(F)

    F_hist = Fs[np.r_[train_idx, val_idx]]
    Y_hist = Y[np.r_[train_idx, val_idx]]
    preds_by_model = {}

    # Fixed metric baselines over full training+val prefix, no online update beyond appending true test points.
    charts, names, balanced, random_mean, identity = build_rw_metric_atlas(Fs.shape[1], seq_len)
    fixed = [(f"fixed_{n}", c) for n, c in zip(names, charts)] + [
        ("fixed_balanced", balanced),
        ("fixed_random_atlas_mean", random_mean),
        ("fixed_identity", identity),
    ]

    for name, diag in fixed:
        histF, histY = F_hist.copy(), Y_hist.copy()
        preds = []
        for idx in test_idx:
            pred = metric_knn_predict(histF, histY, Fs[idx], diag, cfg.k_neighbors)
            preds.append(pred)
            histF = np.vstack([histF, Fs[idx:idx+1]])
            histY = np.vstack([histY, Y[idx:idx+1]])
        preds_by_model[name] = np.asarray(preds)

    # SDRG modes. Warm-start regret on validation prequentially, just as
    # neural models use validation for early stopping/model selection.
    for mode, outname in [("uniform","sdrg_uniform"), ("prior_only","sdrg_prior_only"),
                          ("regret_only","sdrg_regret_only"), ("full","sdrg_geometryguard_full")]:
        model = GeometryGuardRW(cfg, Fs.shape[1], seq_len, mode=mode)

        if cfg.warm_start_on_validation and mode in ("regret_only", "full"):
            warmF, warmY = Fs[train_idx].copy(), Y[train_idx].copy()
            for vidx in val_idx:
                pred_v = model.predict(warmF, warmY, Fs[vidx])
                model.update(Y[vidx])
                warmF = np.vstack([warmF, Fs[vidx:vidx+1]])
                warmY = np.vstack([warmY, Y[vidx:vidx+1]])

        histF, histY = F_hist.copy(), Y_hist.copy()
        preds = []
        for idx in test_idx:
            pred = model.predict(histF, histY, Fs[idx])
            preds.append(pred)
            model.update(Y[idx])
            histF = np.vstack([histF, Fs[idx:idx+1]])
            histY = np.vstack([histY, Y[idx:idx+1]])
        preds_by_model[outname] = np.asarray(preds)

    return preds_by_model, Y[test_idx]

def evaluate_neural(W, Y, train_idx, val_idx, test_idx, cfg):
    if not TORCH_AVAILABLE:
        return {}

    # Scale windows/targets based on train prefix.
    flat_train = W[train_idx].reshape(-1, W.shape[-1])
    x_mu = flat_train.mean(axis=0)
    x_sigma = flat_train.std(axis=0) + 1e-8
    y_mu = Y[train_idx].mean(axis=0)
    y_sigma = Y[train_idx].std(axis=0) + 1e-8

    Ws = (W - x_mu) / x_sigma
    Ys = (Y - y_mu) / y_sigma

    Xtr, ytr = Ws[train_idx], Ys[train_idx]
    Xval, yval = Ws[val_idx], Ys[val_idx]
    Xte = Ws[test_idx]

    kinds = []
    if cfg.include_rnn:
        kinds += ["RNN", "GRU", "LSTM"]
    if cfg.include_transformer:
        kinds += ["Transformer"]

    preds = {}
    for kind in kinds:
        try:
            ps = train_torch_model(kind, Xtr, ytr, Xval, yval, Xte, cfg)
            if ps is not None:
                preds[kind.lower()] = ps * y_sigma + y_mu
        except Exception as e:
            print(f"  neural baseline {kind} failed: {e}")
    return preds


def run_dataset(name, series, cfg):
    if cfg.quick and cfg.max_points_quick is not None and len(series) > cfg.max_points_quick:
        # Use most recent segment for speed while preserving chronological order.
        series = series[-cfg.max_points_quick:]
    F, Y, W = make_causal_features_from_series(series, cfg.seq_len)
    n = len(Y)
    train_idx, val_idx, test_idx = split_indices(n, cfg.train_frac, cfg.val_frac)
    if cfg.quick and cfg.max_test_points_quick is not None and len(test_idx) > cfg.max_test_points_quick:
        test_idx = test_idx[:cfg.max_test_points_quick]

    geom_preds, y_test = evaluate_geometryguard(F, Y, train_idx, val_idx, test_idx, cfg, cfg.seq_len)
    neural_preds = evaluate_neural(W, Y, train_idx, val_idx, test_idx, cfg)

    rows = []
    for model, pred in {**geom_preds, **neural_preds}.items():
        rows.append({
            "dataset": name,
            "model": model,
            "mse": mse(pred, y_test),
            "rmse": rmse(mse(pred, y_test)),
            "mae": mae(pred, y_test),
            "n_test": int(len(y_test)),
        })
    return pd.DataFrame(rows)


def paired_summary(results_df):
    datasets = sorted(results_df["dataset"].unique())
    rows = []

    for ds in datasets:
        sub = results_df[results_df.dataset == ds]
        sdrg = float(sub[sub.model == "sdrg_geometryguard_full"]["mse"].iloc[0])
        # Strong baseline set includes fixed metrics and neural sequence models.
        fair = sub[~sub.model.isin(["sdrg_geometryguard_full", "sdrg_uniform", "sdrg_prior_only", "sdrg_regret_only"])]
        best_row = fair.sort_values("mse").iloc[0]
        gain = 100.0 * (float(best_row.mse) - sdrg) / max(float(best_row.mse), 1e-12)
        rows.append({
            "dataset": ds,
            "best_non_sdrg_model": best_row.model,
            "best_non_sdrg_mse": float(best_row.mse),
            "sdrg_mse": sdrg,
            "relative_gain_pct": gain,
            "sdrg_win": bool(gain > 0),
        })
    return pd.DataFrame(rows)


