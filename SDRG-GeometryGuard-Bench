def rolling_stat(arr, window, fn, default=0.0):
    if len(arr) == 0:
        return default
    v = arr[-window:] if len(arr) >= window else arr
    return float(fn(v))

def make_causal_features_from_series(series: np.ndarray, seq_len: int):
    """
    For each t, build causal features from y[:t+1], target y[t+1].
    Feature vector has:
      recent lags, deltas, rolling means/stds, curvature, momentum, phase.
    Neural baselines use raw lag windows separately.
    """
    y = clean_series(series)
    n = len(y)
    rows, targets, windows = [], [], []

    for t in range(seq_len, n - 1):
        hist = y[:t+1]
        win = y[t-seq_len+1:t+1]
        prev = y[t]
        d1 = y[t] - y[t-1]
        d2 = (y[t] - y[t-1]) - (y[t-1] - y[t-2]) if t >= 2 else 0.0

        feat = []
        # normalized later; raw scale okay here
        feat.extend(win.tolist())                               # seq_len recent values
        feat.extend(np.diff(win, prepend=win[0]).tolist())       # seq_len local deltas
        feat.append(d1)
        feat.append(d2)
        feat.append(rolling_stat(hist, 3, np.mean))
        feat.append(rolling_stat(hist, 6, np.mean))
        feat.append(rolling_stat(hist, 12, np.mean))
        feat.append(rolling_stat(hist, 24, np.mean))
        feat.append(rolling_stat(hist, 6, np.std))
        feat.append(rolling_stat(hist, 12, np.std))
        feat.append(rolling_stat(hist, 24, np.std))
        feat.append(prev - rolling_stat(hist, 12, np.mean))
        feat.append(prev - rolling_stat(hist, 24, np.mean))
        # phase proxies over yearly/monthly-ish windows
        angle = 2 * math.pi * (t % max(2, seq_len)) / max(2, seq_len)
        feat.append(math.sin(angle))
        feat.append(math.cos(angle))

        rows.append(feat)
        targets.append(y[t+1])
        windows.append(win.copy())

    F = np.asarray(rows, dtype=float)
    Y = np.asarray(targets, dtype=float).reshape(-1, 1)
    W = np.asarray(windows, dtype=float).reshape(len(windows), seq_len, 1)
    return F, Y, W

def split_indices(n, train_frac=0.6, val_frac=0.2):
    n_train = int(n * train_frac)
    n_val = int(n * val_frac)
    train = np.arange(0, n_train)
    val = np.arange(n_train, n_train+n_val)
    test = np.arange(n_train+n_val, n)
    return train, val, test


