def run_tests(cfg):
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  GeometryGuard Real-World Benchmark Acceptance Tests                ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")
    checks = []
    def check(name, ok, note=""):
        checks.append(bool(ok))
        print(f"  {'✅' if ok else '❌'} {name:<62} {note}")

    datasets = load_realworld_series()
    check("At least one real-world dataset loads", len(datasets) > 0, list(datasets.keys()))

    name, series = next(iter(datasets.items()))
    F, Y, W = make_causal_features_from_series(series, cfg.seq_len)
    check("Causal feature matrix is 2D", F.ndim == 2, str(F.shape))
    check("Targets align as column vector", Y.ndim == 2 and Y.shape[1] == 1, str(Y.shape))
    check("Neural windows align", W.shape[0] == Y.shape[0], str(W.shape))

    tr, va, te = split_indices(len(Y), cfg.train_frac, cfg.val_frac)
    scaler = TrainScaler().fit(F[tr])
    check("Scaler fits only training prefix", scaler.fit_n_ == len(tr), f"fit_n={scaler.fit_n_}")

    model = GeometryGuardRW(cfg, F.shape[1], cfg.seq_len, mode="full")
    Fs = scaler.transform(F)
    pred = model.predict(Fs[tr], Y[tr], Fs[va[0]])
    check("GeometryGuard prediction shape", pred.shape == (1,), str(pred.shape))
    old = model.loss.copy()
    model.update(Y[va[0]])
    check("GeometryGuard regret updates", np.linalg.norm(model.loss - old) > 0)

    passed = sum(checks)
    print("\n" + "═"*72)
    print(f"  TESTS: {passed}/{len(checks)} passed")
    print("═"*72)
    if passed == len(checks):
        print("ALL TESTS PASSED")
    return passed == len(checks)


