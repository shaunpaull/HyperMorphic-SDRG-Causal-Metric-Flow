    results = pd.concat(all_results, ignore_index=True)
    paired = paired_summary(results)

    print("\n════════════════════════════════════════════════════════════════════════")
    print("PAIRED SUMMARY: SDRG vs BEST NON-SDRG BASELINE")
    print("════════════════════════════════════════════════════════════════════════")
    print(paired.to_string(index=False))

    make_plots(results, paired, cfg)
    zpath = save_artifacts(results, paired, cfg)

    print("\nSaved artifacts:")
    print(f"  {cfg.out_dir}/realworld_model_results.csv")
    print(f"  {cfg.out_dir}/paired_sdrg_vs_best_non_sdrg.csv")
    print(f"  {cfg.out_dir}/benchmark_report.json")
    print(f"  {cfg.out_dir}/RESULTS_CARD.md")
    print(f"  {zpath}")

    return results, paired


