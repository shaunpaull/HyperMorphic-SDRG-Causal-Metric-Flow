def build_rw_metric_atlas(D, seq_len):
    """
    Metric charts over causal engineered feature vector.
    Coordinates:
      0:seq_len             lags
      seq_len:2*seq_len     deltas
      tail                  summary stats
    """
    base = np.ones(D) * 0.05
    charts, names = [], []

    def make(name, idxs, high=4.0, mid=None):
        v = base.copy()
        for i in idxs:
            if 0 <= i < D:
                v[i] = high
        if mid:
            for i in mid:
                if 0 <= i < D:
                    v[i] = max(v[i], 1.0)
        charts.append(v)
        names.append(name)

    lags = list(range(seq_len))
    deltas = list(range(seq_len, 2*seq_len))
    tail0 = 2*seq_len
    recent_lags = list(range(max(0, seq_len-6), seq_len))
    recent_deltas = list(range(seq_len+max(0, seq_len-6), 2*seq_len))

    make("level_recent", recent_lags, high=5.0, mid=[tail0+0, tail0+1, tail0+2])
    make("trend_delta", recent_deltas + [tail0, tail0+1], high=5.0, mid=[tail0+2, tail0+3])
    make("seasonal_phase", [tail0+10, tail0+11], high=5.0, mid=lags[::max(1,seq_len//6)])
    make("volatility", [tail0+4, tail0+5, tail0+6], high=5.0, mid=recent_deltas)
    make("mean_reversion", [tail0+7, tail0+8, tail0+2, tail0+3], high=5.0, mid=recent_lags)
    balanced = np.ones(D)
    random_mean = np.mean(np.asarray(charts), axis=0)
    identity = np.ones(D)
    return np.asarray(charts), names, balanced, random_mean, identity

def metric_knn_predict(F_hist, Y_hist, x, diag, k=24):
    if len(F_hist) == 0:
        return np.zeros(Y_hist.shape[1] if len(Y_hist.shape) > 1 else 1)
    diff = F_hist - x
    d2 = np.sum((diff * diff) * diag, axis=1)
    k_eff = min(k, len(d2))
    idx = np.argpartition(d2, k_eff - 1)[:k_eff]
    dd = d2[idx]
    w = 1.0 / (1e-6 + dd)
    return np.sum(Y_hist[idx] * w[:, None], axis=0) / np.sum(w)

def local_linear_predict(F_hist, Y_hist, x, diag, k=48, ridge=1e-3):
    if len(F_hist) < 4:
        return metric_knn_predict(F_hist, Y_hist, x, diag, k=min(k, max(1, len(F_hist))))
    diff = F_hist - x
    d2 = np.sum((diff * diff) * diag, axis=1)
    k_eff = min(max(k, F_hist.shape[1]//2 + 4), len(d2))
    idx = np.argpartition(d2, k_eff - 1)[:k_eff]
    Xn, Yn = F_hist[idx], Y_hist[idx]
    dd = d2[idx]
    weights = 1.0 / (1e-6 + dd)
    weights = weights / (weights.mean() + 1e-12)
    X = np.column_stack([np.ones(len(idx)), Xn])
    x0 = np.r_[1.0, x]
    Wsqrt = np.sqrt(weights)[:, None]
    Xw = X * Wsqrt
    Yw = Yn * Wsqrt
    reg = ridge * np.eye(X.shape[1])
    reg[0,0] = 0.0
    try:
        beta = np.linalg.solve(Xw.T @ Xw + reg, Xw.T @ Yw)
        return x0 @ beta
    except Exception:
        return metric_knn_predict(F_hist, Y_hist, x, diag, k=min(24, len(F_hist)))

class GeometryGuardRW:
    def __init__(self, cfg, D, seq_len, mode="full"):
        self.cfg, self.D, self.seq_len, self.mode = cfg, D, seq_len, mode
        charts, names, balanced, random_mean, identity = build_rw_metric_atlas(D, seq_len)
        self.charts, self.chart_names = charts, names
        self.experts = []
        for i, name in enumerate(names):
            self.experts.append((f"{name}_knn", "knn", charts[i], i))
        if getattr(self.cfg, "use_local_linear_experts", False):
            for i, name in enumerate(names):
                self.experts.append((f"{name}_local_linear", "ll", charts[i], i))
            self.experts.append(("balanced_local_linear", "ll", balanced, None))
        self.experts.append(("balanced_knn", "knn", balanced, None))
        self.experts.append(("random_mean_knn", "knn", random_mean, None))
        self.experts.append(("identity_knn", "knn", identity, None))

        # Real-world forecasting guards. These are causal experts, not labels.
        # They target common real series structure: persistence, mean reversion,
        # seasonality, and damped trend. They let GeometryGuard compete when
        # the world is trend/seasonality dominated rather than geometry-switch dominated.
        self.experts.append(("persistence_y", "persistence", None, None))
        self.experts.append(("rolling_mean_reversion", "mean_reversion", None, None))
        self.experts.append(("seasonal_naive", "seasonal", None, None))
        self.experts.append(("seasonal_drift", "seasonal_drift", None, None))
        self.experts.append(("damped_trend", "damped_trend", None, None))
        self.loss = np.ones(len(self.experts)) * 0.75
        self.weight_trace = []
        self.expert_names = [e[0] for e in self.experts]
        self.last_preds = None

    def prior(self, x):
        s = self.seq_len
        tail = 2*s
        # Only observable magnitudes from current causal feature.
        return np.array([
            np.linalg.norm(x[max(0,s-6):s]),                 # level
            np.linalg.norm(x[s+max(0,s-6):2*s]) + abs(x[tail]), # trend
            abs(x[tail+10]) + abs(x[tail+11]),                # phase
            abs(x[tail+4]) + abs(x[tail+5]) + abs(x[tail+6]), # volatility
            abs(x[tail+7]) + abs(x[tail+8]),                 # mean reversion
        ])

    def weights(self, x):
        if self.mode == "uniform":
            return np.ones(len(self.experts)) / len(self.experts)
        p5 = self.prior(x)
        priors = []
        for name, kind, diag, idx in self.experts:
            if idx is not None:
                p = p5[idx]
            else:
                p = 0.35 * np.mean(p5)
            if kind == "ll":
                p += 0.10 * (abs(x[2*self.seq_len]) + abs(x[2*self.seq_len+1]))
            elif kind in ("mean_reversion", "seasonal", "seasonal_drift"):
                tail = 2*self.seq_len
                # Mean-reversion features live in tail+7/tail+8; phase in tail+10/tail+11.
                p += 0.20 * (abs(x[tail+7]) + abs(x[tail+8])) + 0.10 * (abs(x[tail+10]) + abs(x[tail+11]))
            elif kind in ("persistence", "damped_trend"):
                p += 0.15 * abs(x[2*self.seq_len])
            priors.append(p)
        priors = np.asarray(priors)
        if self.mode == "prior_only":
            logits = self.cfg.prior_strength * priors
        elif self.mode == "regret_only":
            logits = -self.cfg.sdrg_eta * self.loss
        else:
            # GeometryGuard v2: use the causal prior as a tie-breaker, not a dictator.
            # When online regret has clearly identified a strong real-world expert
            # (e.g. mean reversion on CO2), the prior is automatically damped.
            loss_gap = float(np.median(self.loss) - np.min(self.loss))
            prior_gate = math.exp(-self.cfg.prior_guard_strength * max(0.0, loss_gap))
            logits = (self.cfg.prior_strength * prior_gate) * priors - self.cfg.sdrg_eta * self.loss
        return softmax(logits)

    def expert_predict(self, expert, F_hist, Y_hist, x):
        name, kind, diag, idx = expert
        if kind == "knn":
            return metric_knn_predict(F_hist, Y_hist, x, diag, self.cfg.k_neighbors)
        if kind == "ll":
            return local_linear_predict(F_hist, Y_hist, x, diag, max(2*self.cfg.k_neighbors, 32), self.cfg.ridge)
        if kind == "persistence":
            return Y_hist[-1].copy()
        if kind == "mean_reversion":
            y = Y_hist[:, 0]
            w = min(len(y), max(4, self.cfg.mean_reversion_window))
            mu = float(np.mean(y[-w:]))
            last = float(y[-1])
            if len(y) >= 4:
                trend = float(np.median(np.diff(y[-min(8, len(y)):])) )
            else:
                trend = 0.0
            return np.array([last + 0.35*(mu - last) + 0.25*trend])
        if kind == "seasonal":
            y = Y_hist[:, 0]
            p = int(self.cfg.season_period)
            if len(y) > p:
                return np.array([float(y[-p])])
            return Y_hist[-1].copy()
        if kind == "seasonal_drift":
            y = Y_hist[:, 0]
            p = int(self.cfg.season_period)
            if len(y) > p + 4:
                seasonal = float(y[-p])
                drift = float(np.mean(y[-min(p,len(y)):]) - np.mean(y[-min(2*p,len(y)):-min(p,len(y))])) if len(y) >= 2*p else 0.0
                return np.array([seasonal + 0.5*drift])
            return Y_hist[-1].copy()
        if kind == "damped_trend":
            y = Y_hist[:, 0]
            last = float(y[-1])
            if len(y) >= 6:
                trend = float(np.median(np.diff(y[-6:])))
            elif len(y) >= 2:
                trend = float(y[-1] - y[-2])
            else:
                trend = 0.0
            return np.array([last + 0.7*trend])
        raise ValueError(kind)

    def predict(self, F_hist, Y_hist, x):
        q = self.weights(x)
        preds = np.asarray([self.expert_predict(e, F_hist, Y_hist, x) for e in self.experts])
        self.last_preds = preds
        self.weight_trace.append(q.copy())
        return np.sum(preds * q[:, None], axis=0)

    def update(self, y_true):
        if self.mode in ("uniform", "prior_only"):
            return
        losses = np.asarray([mse(p, y_true) for p in self.last_preds])
        scale = np.median(losses) + 1e-8
        normalized = np.clip(losses / scale, 0.0, 6.0)
        self.loss = (1 - self.cfg.sdrg_alpha) * self.loss + self.cfg.sdrg_alpha * normalized


