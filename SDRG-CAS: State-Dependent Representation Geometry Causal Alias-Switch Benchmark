# MAIN
# ═══════════════════════════════════════════════════════════════════════

def run_production_benchmark(cfg=BenchmarkConfig()):
    os.makedirs(cfg.out_dir, exist_ok=True)

    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG Causal Metric Flow v2 — Production Benchmark                  ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")
    print(json.dumps(asdict(cfg), indent=2))

    tests_ok, leakage_audit = run_sanity_tests(cfg)

    if not tests_ok:
        raise RuntimeError("Sanity tests failed; benchmark stopped.")

    all_summaries = []
    all_steps = []
    representative = None

    t0 = time.perf_counter()

    for seed in cfg.seeds:
        print(f"\nRunning seed {seed}...")

        summary, steps, traces, F_raw, Y, regimes = run_single_seed(seed, cfg)
        all_summaries.append(summary)

        if cfg.save_per_step:
            all_steps.append(steps)

        if representative is None:
            representative = {
                "traces": traces,
                "regimes": regimes,
            }

        p = summary.pivot(index="seed", columns="model", values="mse")
        fixed_cols = [c for c in p.columns if c.startswith("fixed_")]

        best_fixed = p[fixed_cols].min(axis=1).iloc[0]
        best_name = p[fixed_cols].idxmin(axis=1).iloc[0]

        sdrg = p["sdrg_full"].iloc[0]
        gain = 100.0 * (best_fixed - sdrg) / best_fixed

        print(f"  best_fixed_metric={best_name} {best_fixed:.6f}")
        print(f"  sdrg_full={sdrg:.6f}")
        print(f"  relative_gain={gain:.2f}%")

    summary_df = pd.concat(all_summaries, ignore_index=True)
    step_df = pd.concat(all_steps, ignore_index=True) if all_steps else pd.DataFrame()

    report, paired_df = statistical_report(summary_df, cfg)
    report["runtime_seconds"] = float(time.perf_counter() - t0)

    print("\n════════════════════════════════════════════════════════════════════════")
    print("FINAL STATISTICAL REPORT")
    print("════════════════════════════════════════════════════════════════════════")
    print(json.dumps(report, indent=2))

    print("\nMean MSE by model:")
    print(
        summary_df.groupby("model")["mse"]
        .mean()
        .sort_values()
        .to_string()
    )

    make_plots(summary_df, paired_df, representative, cfg)

    zip_path = save_artifacts(
        summary_df,
        step_df,
        paired_df,
        report,
        leakage_audit,
        cfg,
    )

    print("\nSaved artifacts:")
    print(f"  {cfg.out_dir}/run_summary_by_seed_model.csv")
    print(f"  {cfg.out_dir}/paired_sdrg_vs_best_fixed_metric.csv")
    print(f"  {cfg.out_dir}/benchmark_report.json")
    print(f"  {cfg.out_dir}/RESULTS_CARD.md")
    print(f"  {zip_path}")

    return summary_df, step_df, report, paired_df


