        f.write("- Primary task: causal alias-switch benchmark where correct geometry changes by regime.\n")

    zip_path = os.path.join(out, "sdrg_cmf_v2_alias_benchmark_artifacts.zip")

    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as z:
        for root, _, files in os.walk(out):
            for file in files:
                if file.endswith(".zip"):
                    continue
                full = os.path.join(root, file)
                z.write(full, arcname=os.path.relpath(full, out))

    return zip_path


