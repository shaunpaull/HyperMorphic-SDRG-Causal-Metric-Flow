# UTILITIES
# ═══════════════════════════════════════════════════════════════════════

def set_seed(seed: int):
    random.seed(seed)
    np.random.seed(seed)


def softmax(logits):
    z = np.asarray(logits, dtype=float)
    z = z - np.max(z)
    e = np.exp(z)
    return e / np.sum(e)


def mse(a, b):
    d = np.asarray(a) - np.asarray(b)
    return float(np.mean(d * d))


def mae(a, b):
    return float(np.mean(np.abs(np.asarray(a) - np.asarray(b))))


def rmse(x):
    return float(np.sqrt(max(0.0, x)))


def bootstrap_ci(values, n_boot=1000, seed=123):
    rng = np.random.default_rng(seed)
    vals = np.asarray(values, dtype=float)

    boots = []
    for _ in range(n_boot):
        sample = rng.choice(vals, size=len(vals), replace=True)
        boots.append(float(np.mean(sample)))

    return [
        float(np.percentile(boots, 2.5)),
        float(np.percentile(boots, 97.5)),
    ]


# ═══════════════════════════════════════════════════════════════════════
# DATASET — CAUSAL ALIAS-SWITCH GEOMETRY TASK
# ═══════════════════════════════════════════════════════════════════════

def make_causal_alias_switch_task(seed=0, T=1600, noise=0.020):
    """
    Production SDRG benchmark task.

    This is deliberately not a simple position-Markov task.

    The correct predictive geometry switches across regimes:
      regime 0: position chart matters
      regime 1: velocity chart matters
      regime 2: acceleration chart matters
      regime 3: curvature chart matters
      regime 4: phase chart matters

    All features are observable and causal.
    Hidden regime labels are NEVER given to any model.

    The benchmark tests whether a model can adapt the metric of similarity
    over time instead of relying on one fixed geometry.
    """
    rng = np.random.default_rng(seed)

    regimes = []
    t = 0
    r = int(rng.integers(0, 5))

    while t < T:
        duration = int(rng.integers(45, 90))
        r = int((r + rng.choice([1, 2, 3, 4])) % 5)
        regimes += [r] * duration
        t += duration

    regimes = np.asarray(regimes[:T])

    # Smooth latent process. This gives causal continuity but does not reveal
    # the hidden regime directly.
    latent = np.zeros((T, 12), dtype=float)
    latent[0] = rng.normal(size=12)

    for t in range(1, T):
        latent[t] = 0.92 * latent[t - 1] + 0.35 * rng.normal(size=12)

    F = np.zeros((T, 12), dtype=float)
    Y = np.zeros((T, 2), dtype=float)

    chart_dims = {
        0: (0, 1),     # position-like
        1: (2, 3),     # velocity-like
        2: (4, 5),     # acceleration-like
        3: (8, 9),     # curvature-like
        4: (10, 11),   # phase-like
    }

    for t in range(T):
        r = int(regimes[t])

        # Nuisance features. Fixed all-feature geometry gets contaminated.
        F[t] = 0.80 * rng.normal(size=12)
        F[t] += 0.30 * latent[t]

        a, b = chart_dims[r]

        # Active chart dimensions become high-SNR for this regime.
        F[t, a] = 2.50 * latent[t, a] + 0.10 * rng.normal()
        F[t, b] = 2.50 * latent[t, b] + 0.10 * rng.normal()

        u, v = F[t, a], F[t, b]

        # Target depends on the active geometry, not on a fixed coordinate set.
        Y[t] = np.array([
            np.sin(u) + 0.30 * v,
            np.cos(v) - 0.20 * u,
        ]) + noise * rng.normal(size=2)

    return F, Y, regimes


class PrefixStandardizer:
    """
    Leak-safe scaler: fit only on warmup prefix.
    """
    def fit(self, X):
        self.mu = X.mean(axis=0)
        self.sigma = X.std(axis=0) + 1e-6
        return self

    def transform(self, X):
        return (X - self.mu) / self.sigma


# ═══════════════════════════════════════════════════════════════════════
# METRIC KNN ENGINE
# ═══════════════════════════════════════════════════════════════════════

def metric_knn_predict(F, Y, t, diag_metric, k=12, warmup=100):
    """
    Prequential metric KNN.

    To predict Y[t], this function may only use rows i < t.
    """
    if t <= 0:
        return np.zeros(Y.shape[1], dtype=float)

    if t < warmup:
        return Y[:t].mean(axis=0)

    Xpast = F[:t]
    diff = Xpast - F[t]
    d2 = np.sum((diff * diff) * diag_metric, axis=1)

    k_eff = min(k, len(d2))
    idx = np.argpartition(d2, k_eff - 1)[:k_eff]

    dd = d2[idx]
    weights = 1.0 / (1e-6 + dd)

    return np.sum(Y[idx] * weights[:, None], axis=0) / np.sum(weights)


# ═══════════════════════════════════════════════════════════════════════
# METRIC ATLAS
# ═══════════════════════════════════════════════════════════════════════

def build_metric_atlas():
    D = 12
    base = np.ones(D) * 0.05
    charts = []
    names = []

    def make(name, weights):
        v = base.copy()
        for idx, value in weights.items():
            v[idx] = value
        charts.append(v)
        names.append(name)

    make("position", {
        0: 5.0,
        1: 5.0,
    })

    make("velocity", {
        2: 5.0,
        3: 5.0,
        6: 1.0,
        10: 0.5,
        11: 0.5,
    })

    make("acceleration", {
        4: 5.0,
        5: 5.0,
        7: 1.0,
    })

    make("curvature", {
        8: 6.0,
        9: 5.0,
    })

    make("phase", {
        10: 5.0,
        11: 5.0,
        6: 1.0,
    })

    make("balanced", {
        i: 1.0 for i in range(D)
    })

    return np.asarray(charts, dtype=float), names


