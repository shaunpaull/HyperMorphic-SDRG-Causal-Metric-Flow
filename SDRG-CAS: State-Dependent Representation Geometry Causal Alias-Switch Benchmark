        "fixed_position",
        "fixed_velocity",
        "fixed_acceleration",
        "fixed_curvature",
        "fixed_phase",
        "fixed_balanced",
        "sdrg_uniform",
        "sdrg_prior_only",
        "sdrg_regret_only",
        "sdrg_full",
    ]

    agg = summary_df.groupby("model").agg(
        mean_mse=("mse", "mean"),
        std_mse=("mse", "std"),
