def run_single_seed(seed, cfg):
    set_seed(seed)

    F_raw, Y, regimes = make_causal_alias_switch_task(
        seed=seed,
        T=cfg.T,
        noise=cfg.noise,
    )

    scaler = PrefixStandardizer().fit(F_raw[:cfg.warmup])
    F = scaler.transform(F_raw)

    models = make_models()

    for model in models:
        model.reset(cfg)

    rows = []
    step_rows = []

    for t in range(cfg.warmup, len(Y)):
        # Predict first.
        predictions = {}

        for model in models:
            predictions[model.name] = model.predict(F, Y, t)

        # Score.
        for model in models:
            e_mse = mse(predictions[model.name], Y[t])
            e_mae = mae(predictions[model.name], Y[t])

            rows.append({
                "seed": seed,
                "model": model.name,
                "mse": e_mse,
                "mae": e_mae,
            })

            if cfg.save_per_step:
                step_rows.append({
                    "seed": seed,
                    "t": t,
                    "regime": int(regimes[t]),
                    "model": model.name,
                    "mse": e_mse,
                    "mae": e_mae,
                })

        # Update only after observing Y[t].
        for model in models:
            model.update(F, Y, t)

    df = pd.DataFrame(rows)

    summary = df.groupby(["seed", "model"]).agg(
        mse=("mse", "mean"),
        mae=("mae", "mean"),
    ).reset_index()

    summary["rmse"] = summary["mse"].map(rmse)

    traces = {}

    for model in models:
        if isinstance(model, SDRGCausalMetricFlow):
            traces[model.name] = {
                "weights": np.asarray(model.weight_trace),
                "metric_volume": np.asarray(model.metric_volume_trace),
                "chart_names": model.specialist_names,
            }

    return summary, pd.DataFrame(step_rows), traces, F_raw, Y, regimes


def statistical_report(summary_df, cfg):
    pivot = summary_df.pivot(index="seed", columns="model", values="mse")

    fixed_cols = [
        c for c in pivot.columns
        if c.startswith("fixed_")
    ]

    pivot["best_fixed_metric"] = pivot[fixed_cols].min(axis=1)
    pivot["best_fixed_metric_name"] = pivot[fixed_cols].idxmin(axis=1)

    target = "sdrg_full"

    pivot["absolute_gain"] = pivot["best_fixed_metric"] - pivot[target]
    pivot["relative_gain_pct"] = (
        100.0 * pivot["absolute_gain"] / pivot["best_fixed_metric"].clip(lower=1e-12)
    )

    rel = pivot["relative_gain_pct"].values
    diff = pivot["absolute_gain"].values

    report = {
        "n_seeds": int(len(pivot)),
        "mean_best_fixed_metric_mse": float(pivot["best_fixed_metric"].mean()),
        "mean_sdrg_full_mse": float(pivot[target].mean()),
        "mean_absolute_mse_gain": float(np.mean(diff)),
        "mean_relative_gain_pct": float(np.mean(rel)),
        "median_relative_gain_pct": float(np.median(rel)),
        "win_rate_vs_best_fixed_metric": float(np.mean(diff > 0)),
        "relative_gain_ci95_pct": bootstrap_ci(
            rel,
            n_boot=cfg.bootstrap_samples,
        ),
    }

    if SCIPY_AVAILABLE and len(pivot) >= 3:
        try:
            report["paired_ttest_p_sdrg_less_than_best_fixed"] = float(
                ttest_rel(
                    pivot[target],
                    pivot["best_fixed_metric"],
                    alternative="less",
                ).pvalue
            )
        except Exception:
            report["paired_ttest_p_sdrg_less_than_best_fixed"] = None

        try:
            report["wilcoxon_p_sdrg_less_than_best_fixed"] = float(
                wilcoxon(
                    pivot[target],
                    pivot["best_fixed_metric"],
                    alternative="less",
                ).pvalue
            )
        except Exception:
            report["wilcoxon_p_sdrg_less_than_best_fixed"] = None

    return report, pivot.reset_index()


