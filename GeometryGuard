CHART_DIMS = {
    0: (0, 1),      # position-like
    1: (2, 3),      # velocity-like
    2: (4, 5),      # acceleration-like
    3: (8, 9),      # curvature-like
    4: (10, 11),    # phase-like
}

def regime_schedule(seed, T, n_regimes=5, lo=45, hi=95):
    rng = np.random.default_rng(seed + 777)
    regimes, t = [], 0
    r = int(rng.integers(0, n_regimes))
    while t < T:
        dur = int(rng.integers(lo, hi))
        r = int((r + rng.choice(list(range(1, n_regimes)))) % n_regimes)
        regimes += [r] * dur
        t += dur
    return np.asarray(regimes[:T])

def make_alias_switch_task(seed=0, T=1200, noise=0.02, mode="abrupt", feature_dropout=0.0):
    """
    Controlled SDRG task. The predictive target depends on different feature
    subspaces over time. Hidden regimes are for audit only.
    """
    rng = np.random.default_rng(seed)
    regimes = regime_schedule(seed, T, 5, 45, 90)
    latent = np.zeros((T, 12))
    latent[0] = rng.normal(size=12)
    for t in range(1, T):
        latent[t] = 0.92 * latent[t-1] + 0.35 * rng.normal(size=12)

    F = np.zeros((T, 12))
    Y = np.zeros((T, 2))

    for t in range(T):
        r = int(regimes[t])
        F[t] = 0.80 * rng.normal(size=12) + 0.30 * latent[t]

        if mode == "gradual":
            # Soft interpolation between active chart r and next chart.
            period = 80
            frac = (t % period) / period
            r2 = (r + 1) % 5
            a1, b1 = CHART_DIMS[r]
            a2, b2 = CHART_DIMS[r2]
            F[t, a1] = (1-frac) * 2.50 * latent[t, a1] + 0.10 * rng.normal()
            F[t, b1] = (1-frac) * 2.50 * latent[t, b1] + 0.10 * rng.normal()
            F[t, a2] = frac * 2.50 * latent[t, a2] + 0.10 * rng.normal()
            F[t, b2] = frac * 2.50 * latent[t, b2] + 0.10 * rng.normal()
            u = (1-frac) * F[t, a1] + frac * F[t, a2]
            v = (1-frac) * F[t, b1] + frac * F[t, b2]
        else:
            a, b = CHART_DIMS[r]
            F[t, a] = 2.50 * latent[t, a] + 0.10 * rng.normal()
            F[t, b] = 2.50 * latent[t, b] + 0.10 * rng.normal()
            u, v = F[t, a], F[t, b]

        Y[t] = np.array([np.sin(u) + 0.30*v, np.cos(v) - 0.20*u]) + noise * rng.normal(size=2)

    if feature_dropout > 0:
        mask = rng.random(F.shape) > feature_dropout
        F = F * mask

    return F, Y, regimes

def make_continual_memory_task(seed=0, T=1000, noise=0.02):
    """Sequential A→B→C→D→E where E revisits A with drift."""
    rng = np.random.default_rng(seed + 123)
    tasks = [0, 1, 2, 3, 0]
    segment = T // len(tasks)
    regimes = np.concatenate([np.full(segment, task) for task in tasks])
    if len(regimes) < T:
        regimes = np.concatenate([regimes, np.full(T-len(regimes), tasks[-1])])
    regimes = regimes[:T]

    latent = np.zeros((T, 12))
    latent[0] = rng.normal(size=12)
    for t in range(1, T):
        latent[t] = 0.93 * latent[t-1] + 0.30 * rng.normal(size=12)

    F = 0.75 * rng.normal(size=(T, 12)) + 0.25 * latent
    Y = np.zeros((T, 2))

    for t, r in enumerate(regimes):
        a, b = CHART_DIMS[int(r)]
        drift = 0.25 if t >= 4*segment else 0.0
        F[t, a] = 2.35 * latent[t, a] + drift + 0.08 * rng.normal()
        F[t, b] = 2.35 * latent[t, b] - drift + 0.08 * rng.normal()
        u, v = F[t, a], F[t, b]
        Y[t] = np.array([np.sin(u) + 0.25*v, np.cos(v) - 0.18*u]) + noise * rng.normal(size=2)

    return F, Y, regimes

def rotation(theta, scale=0.985):
    c, s = np.cos(theta), np.sin(theta)
    return scale * np.array([[c, -s], [s, c]], dtype=float)

def make_dynamical_system(seed=0, T=1000, noise=0.025):
    """
    Nonlinear regime-switching dynamics. This was the failure case for v2.
    v3 should improve by guarding around position/persistence/local-linear experts.
    """
    rng = np.random.default_rng(seed)
    regimes = regime_schedule(seed, T+1, 4, 35, 95)

    A = [
        rotation(+0.25),
        rotation(-0.25),
        np.array([[1.020, 0.080], [0.000, 0.940]], dtype=float),
        np.array([[0.940, 0.000], [-0.080, 1.020]], dtype=float),
    ]

    x = np.zeros((T+1, 2), dtype=float)
    x[0] = rng.normal(size=2) * 0.50
    x[1] = x[0] + rng.normal(size=2) * 0.10

    for i in range(1, T):
        r = int(regimes[i])
        prev = x[i]
        vel = x[i] - x[i-1]
        if r == 0:
            nxt = A[r] @ prev + 0.22*np.tanh(np.array([vel[1], -vel[0]]))
        elif r == 1:
            nxt = A[r] @ prev + 0.22*np.tanh(np.array([-vel[1], vel[0]]))
        elif r == 2:
            nxt = A[r] @ prev + 0.12*np.array([np.sin(2*prev[1]), np.cos(prev[0])])
        else:
            nxt = A[r] @ prev + 0.12*np.array([np.cos(prev[1]), -np.sin(2*prev[0])])
        nxt += noise * rng.normal(size=2)
        norm = np.linalg.norm(nxt)
        if norm > 3.5:
            nxt = nxt / norm * 3.5
        x[i+1] = nxt

    F = build_causal_features_from_trajectory(x)
    Y = x[1:]
    return F, Y, regimes[:T]

def build_causal_features_from_trajectory(x):
    T = len(x) - 1
    F = np.zeros((T, 12), dtype=float)
    for t in range(T):
        pos = x[t]
        v = x[t] - x[t-1] if t >= 1 else np.zeros(2)
        v_prev = x[t-1] - x[t-2] if t >= 2 else np.zeros(2)
        a = v - v_prev
        speed = np.linalg.norm(v)
        acc = np.linalg.norm(a)
        cross = v[0]*a[1] - v[1]*a[0]
        dot = float(v @ a)
        angle = np.arctan2(v[1], v[0]) if speed > 1e-9 else 0.0
        F[t] = [pos[0], pos[1], v[0], v[1], a[0], a[1], speed, acc, cross, dot, np.sin(angle), np.cos(angle)]
    return F


