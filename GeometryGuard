def build_metric_atlas():
    """Five specialist charts plus balanced/random/identity fixed baselines."""
    D = 12
    base = np.ones(D) * 0.05
    charts, names = [], []

    def make(name, weights):
        v = base.copy()
        for idx, value in weights.items():
            v[idx] = value
        charts.append(v)
        names.append(name)

    make("position",     {0: 5.0, 1: 5.0})
    make("velocity",     {2: 5.0, 3: 5.0, 6: 1.0, 10: 0.5, 11: 0.5})
    make("acceleration", {4: 5.0, 5: 5.0, 7: 1.0})
    make("curvature",    {8: 6.0, 9: 5.0})
    make("phase",        {10: 5.0, 11: 5.0, 6: 1.0})

    balanced = np.ones(D)
    random_atlas_mean = np.mean(np.asarray(charts), axis=0)
    identity = np.ones(D)

    return np.asarray(charts, dtype=float), names, balanced, random_atlas_mean, identity


