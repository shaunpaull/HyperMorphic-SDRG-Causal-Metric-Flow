def metric_knn_predict(F, Y, t, diag_metric, k=24, warmup=80):
    if t <= 0:
        return np.zeros(Y.shape[1])
    if t < warmup:
        return Y[:t].mean(axis=0)
    diff = F[:t] - F[t]
    d2 = np.sum((diff*diff) * diag_metric, axis=1)
    k_eff = min(k, len(d2))
    idx = np.argpartition(d2, k_eff-1)[:k_eff]
    dd = d2[idx]
    w = 1.0 / (1e-6 + dd)
    return np.sum(Y[idx] * w[:, None], axis=0) / np.sum(w)

def local_linear_metric_predict(F, Y, t, diag_metric, k=48, warmup=80, ridge=1e-3):
    """
    Local linear regression on metric nearest neighbors.
    Better for smooth dynamical systems than constant kNN.
    """
    if t <= 2:
        return Y[:max(t,1)].mean(axis=0) if t > 0 else np.zeros(Y.shape[1])
    if t < warmup:
        return Y[:t].mean(axis=0)

    diff = F[:t] - F[t]
    d2 = np.sum((diff*diff) * diag_metric, axis=1)
    k_eff = min(max(k, F.shape[1]+4), len(d2))
    idx = np.argpartition(d2, k_eff-1)[:k_eff]
    Xn = F[idx]
    Yn = Y[idx]

    # Weighted ridge local linear model.
    dd = d2[idx]
    weights = 1.0 / (1e-6 + dd)
    weights = weights / (weights.mean() + 1e-12)

    X = np.column_stack([np.ones(len(idx)), Xn])
    x0 = np.r_[1.0, F[t]]

    Wsqrt = np.sqrt(weights)[:, None]
    Xw = X * Wsqrt
    Yw = Yn * Wsqrt

    reg = ridge * np.eye(X.shape[1])
    reg[0,0] = 0.0

    try:
        beta = np.linalg.solve(Xw.T @ Xw + reg, Xw.T @ Yw)
        return x0 @ beta
    except np.linalg.LinAlgError:
        return metric_knn_predict(F, Y, t, diag_metric, k=min(24,k_eff), warmup=warmup)

def persistence_predict(F, Y, t):
    # For trajectory tasks Y is next position and F[:2] is current position.
    return F[t, :2].copy()


