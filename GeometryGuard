def make_plots(summary_df, paired_df, traces, regimes, reports, cfg):
    out = cfg.out_dir
    os.makedirs(out, exist_ok=True)

    # Leaderboard for main tasks.
    for bench in ["sdrg_cas", "dynamical_system", "continual_memory", "abrupt_drift", "gradual_drift"]:
        sub = summary_df[summary_df["benchmark"] == bench]
        if sub.empty: continue
        agg = sub.groupby("model").agg(mean_mse=("mse","mean"), std_mse=("mse","std")).sort_values("mean_mse")
        plt.figure(figsize=(12,5))
        plt.bar(range(len(agg)), agg["mean_mse"], yerr=agg["std_mse"], capsize=3)
        plt.xticks(range(len(agg)), agg.index, rotation=35, ha="right")
        plt.ylabel("Mean prequential MSE")
        plt.title(f"Leaderboard: {bench}")
        plt.tight_layout()
        plt.savefig(os.path.join(out, f"leaderboard_{bench}.png"), dpi=180)
        plt.close()

    # Relative gains.
    all_pairs = pd.concat(paired_df, ignore_index=True)
    plt.figure(figsize=(12,5))
    order = ["sdrg_cas", "continual_memory", "abrupt_drift", "gradual_drift", "dynamical_system"]
    vals = [reports[b]["mean_relative_gain_pct"] for b in order if b in reports]
    labels = [b for b in order if b in reports]
    colors = ["tab:green" if v >= 0 else "tab:red" for v in vals]
    plt.bar(labels, vals, color=colors)
    plt.axhline(0, color="black", linewidth=1)
    plt.xticks(rotation=25, ha="right")
    plt.ylabel("Mean gain vs best fixed metric (%)")
    plt.title("SDRG-CMF v3 GeometryGuard: gain/loss boundary")
    plt.tight_layout()
    plt.savefig(os.path.join(out, "matched_seed_relative_gain_summary.png"), dpi=180)
    plt.close()

    if traces and "weights" in traces:
        W = traces["weights"]
        names = traces["expert_names"]
        top = np.argsort(W.mean(axis=0))[-8:][::-1]
        plt.figure(figsize=(13,5))
        for i in top:
            plt.plot(W[:, i], label=names[i], linewidth=1.1)
        plt.legend(ncol=2, fontsize=8)
        plt.title("SDRG v3 GeometryGuard expert routing weights")
        plt.xlabel("evaluation step")
        plt.ylabel("routing weight")
        plt.tight_layout()
        plt.savefig(os.path.join(out, "sdrg_v3_expert_weights.png"), dpi=180)
        plt.close()

        plt.figure(figsize=(12,3))
        plt.plot(traces["metric_volume"], linewidth=1.2)
        plt.title("Metric volume proxy")
        plt.tight_layout()
        plt.savefig(os.path.join(out, "metric_volume_proxy.png"), dpi=180)
        plt.close()

    if regimes is not None:
        plt.figure(figsize=(12,3))
        plt.plot(regimes, linewidth=1.0)
        plt.title("Hidden regime audit plot — never given to non-oracle models")
        plt.tight_layout()
        plt.savefig(os.path.join(out, "hidden_regime_audit.png"), dpi=180)
        plt.close()

def write_results_card(reports, cfg):
    out = cfg.out_dir
    with open(os.path.join(out, "RESULTS_CARD.md"), "w") as f:
        f.write("# SDRG-CMF v3 GeometryGuard Results\n\n")
        f.write("## What changed\n\n")
        f.write("v3 adds GeometryGuard: a guarded Hedge ensemble over SDRG metric-chart experts, local-linear chart experts, and a position/persistence safety path. This is intended to preserve SDRG wins on geometry-switching tasks while reducing failure on dynamical systems where one geometry dominates.\n\n")
        f.write("## Main reports\n\n")
        for name, rep in reports.items():
            f.write(f"### {name}\n")
            for k, v in rep.items():
                if k != "benchmark":
                    f.write(f"- **{k}:** {v}\n")
            f.write("\n")
        f.write("## Claim discipline\n\n")
        f.write("Allowed claim: SDRG-CMF v3 is a controlled benchmark/model prototype for state-dependent metric learning and continual-memory style adaptation.\n\n")
        f.write("Not claimed: state-of-the-art ML, transformer superiority, solved continual learning, production readiness, biological proof, or universal superiority.\n")

def save_artifacts(summary_df, step_df, paired_tables, reports, cfg):
    out = cfg.out_dir
    os.makedirs(out, exist_ok=True)
    summary_df.to_csv(os.path.join(out, "run_summary_by_seed_model.csv"), index=False)
    step_df.to_csv(os.path.join(out, "per_step_errors.csv"), index=False)
    pd.concat(paired_tables, ignore_index=True).to_csv(os.path.join(out, "paired_sdrg_vs_best_fixed.csv"), index=False)

    payload = {
        "config": asdict(cfg),
        "reports": reports,
        "environment": {
            "python": sys.version,
            "platform": platform.platform(),
            "numpy": np.__version__,
            "pandas": pd.__version__,
            "scipy_available": SCIPY_AVAILABLE,
        },
        "claim_discipline": {
            "allowed": [
                "controlled evidence for state-dependent metric learning",
                "GeometryGuard improves robustness on dynamical tasks compared with unguarded SDRG",
                "results are benchmark-specific",
            ],
            "not_claimed": [
                "SOTA ML",
                "beats transformers",
                "solves continual learning",
                "universal superiority",
            ],
        },
    }
    with open(os.path.join(out, "benchmark_report.json"), "w") as f:
        json.dump(payload, f, indent=2)

    write_results_card(reports, cfg)

    zpath = os.path.join(out, "sdrg_cmf_v3_geometryguard_artifacts.zip")
    with zipfile.ZipFile(zpath, "w", zipfile.ZIP_DEFLATED) as z:
        for root, _, files in os.walk(out):
            for file in files:
                if file.endswith(".zip"): continue
                full = os.path.join(root, file)
                z.write(full, arcname=os.path.relpath(full, out))
    return zpath


