def run_acceptance_tests(cfg):
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG-CMF v3 GeometryGuard Acceptance Tests                         ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")
    results = []
    def check(name, ok, note=""):
        results.append(bool(ok))
        print(f"  {'✅' if ok else '❌'} {name:<62} {note}")

    F_raw, Y, regimes = make_alias_switch_task(seed=42, T=180, noise=cfg.noise)
    scaler = PrefixStandardizer().fit(F_raw[:60])
    F = scaler.transform(F_raw)

    check("Features have correct shape", F.shape == (180, 12), str(F.shape))
    check("Targets align correctly", Y.shape == (180, 2), str(Y.shape))
    check("Scaler fits only warmup prefix", scaler.fit_n_ == 60, f"fit_n={scaler.fit_n_}")
    check("Hidden regimes exist for audit only", regimes.shape == (180,), str(regimes.shape))

    m = SDRGFullV3GeometryGuard("full_v3")
    m.reset(cfg)
    pred = m.predict(F, Y, cfg.warmup, regimes)
    G, q = m.current_metric(F[cfg.warmup])

    check("Prediction is 2D", pred.shape == (2,), str(pred.shape))
    check("Router weights sum to 1", abs(q.sum()-1) < 1e-9, f"sum={q.sum()}")
    check("Metric entries positive", np.all(G > 0), f"min={G.min():.5f}")

    old_loss = m.loss.copy()
    m.update(F, Y, cfg.warmup, pred, regimes)
    check("Online regret updates after scoring", np.linalg.norm(m.loss-old_loss) > 0)

    # Determinism.
    s1, _, _, _, _, _ = run_one(0, "sdrg_cas", cfg, T=220, noise=cfg.noise)
    s2, _, _, _, _, _ = run_one(0, "sdrg_cas", cfg, T=220, noise=cfg.noise)
    check("Deterministic rerun with same seed", np.allclose(s1["mse"].values, s2["mse"].values))

    expected_cols = {"benchmark", "seed", "model", "mse", "mae", "rmse"}
    check("All summary columns exist", expected_cols.issubset(set(s1.columns)), str(s1.columns.tolist()))

    passed, total = sum(results), len(results)
    print("\n" + "═"*72)
    print(f"  TESTS: {passed}/{total} passed")
    print("═"*72)
    if passed == total:
        print("ALL TESTS PASSED")
    else:
        print("TESTS FAILED")
    return passed == total


