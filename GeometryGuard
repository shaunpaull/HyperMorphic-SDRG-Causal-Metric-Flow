def get_dataset(name, seed, T, noise):
    if name == "sdrg_cas":
        return make_alias_switch_task(seed, T, noise, mode="abrupt")
    if name == "continual_memory":
        return make_continual_memory_task(seed, T, noise)
    if name == "abrupt_drift":
        return make_alias_switch_task(seed, T, noise, mode="abrupt")
    if name == "gradual_drift":
        return make_alias_switch_task(seed, T, noise, mode="gradual")
    if name == "dynamical_system":
        return make_dynamical_system(seed, T, noise)
    raise ValueError(name)

FAIR_FIXED_PREFIXES = ("fixed_",)
EXCLUDE_FROM_BEST = ("diagnostic_", "oracle_", "sdrg_")

def run_one(seed, dataset_name, cfg, T=None, noise=None):
    T = cfg.T_main if T is None else T
    noise = cfg.noise if noise is None else noise

    F_raw, Y, regimes = get_dataset(dataset_name, seed, T, noise)
    scaler = PrefixStandardizer().fit(F_raw[:cfg.warmup])
    F = scaler.transform(F_raw)

    models = make_models(include_oracle=True, include_local_linear_baselines=True)
    for m in models:
        m.reset(cfg)

    rows, steps = [], []

    for t in range(cfg.warmup, len(Y)):
        preds = {}
        # Predict before update.
        for m in models:
            preds[m.name] = m.predict(F, Y, t, regimes=regimes)

        # Score.
        for m in models:
            e_mse = mse(preds[m.name], Y[t])
            e_mae = mae(preds[m.name], Y[t])
            rows.append({
                "benchmark": dataset_name,
                "seed": seed,
                "model": m.name,
                "mse": e_mse,
                "mae": e_mae,
            })
            if cfg.save_per_step:
                steps.append({
                    "benchmark": dataset_name,
                    "seed": seed,
                    "t": t,
                    "regime": int(regimes[t]),
                    "model": m.name,
                    "mse": e_mse,
                    "mae": e_mae,
                })

        # Update after scoring.
        for m in models:
            m.update(F, Y, t, preds[m.name], regimes=regimes)

    summary = pd.DataFrame(rows).groupby(["benchmark", "seed", "model"]).agg(
        mse=("mse", "mean"),
        mae=("mae", "mean")
    ).reset_index()
    summary["rmse"] = summary["mse"].map(rmse)

    traces = {}
    for m in models:
        if isinstance(m, SDRGFullV3GeometryGuard) and m.name == "sdrg_full_v3":
            traces["weights"] = np.asarray(m.weight_trace)
            traces["metric_volume"] = np.asarray(m.metric_volume_trace)
            traces["expert_names"] = m.expert_names

    return summary, pd.DataFrame(steps), traces, F_raw, Y, regimes

def paired_report(summary_df, benchmark, cfg):
    sub = summary_df[summary_df["benchmark"] == benchmark]
    pivot = sub.pivot(index="seed", columns="model", values="mse")

    fixed_cols = [c for c in pivot.columns if c.startswith("fixed_")]
    # Pure fixed metric KNN baselines only.
    pivot["best_fixed"] = pivot[fixed_cols].min(axis=1)
    pivot["best_fixed_name"] = pivot[fixed_cols].idxmin(axis=1)

    target = "sdrg_full_v3"
    pivot["absolute_gain"] = pivot["best_fixed"] - pivot[target]
    pivot["relative_gain_pct"] = 100 * pivot["absolute_gain"] / pivot["best_fixed"].clip(lower=1e-12)

    rel = pivot["relative_gain_pct"].values
    diff = pivot["absolute_gain"].values

    rep = {
        "benchmark": benchmark,
        "n_seeds": int(len(pivot)),
        "mean_best_fixed_mse": float(pivot["best_fixed"].mean()),
        "mean_sdrg_full_v3_mse": float(pivot[target].mean()),
        "mean_absolute_gain": float(np.mean(diff)),
        "mean_relative_gain_pct": float(np.mean(rel)),
        "median_relative_gain_pct": float(np.median(rel)),
        "win_rate_vs_best_fixed": float(np.mean(diff > 0)),
        "relative_gain_ci95_pct": bootstrap_ci(rel, cfg.bootstrap_samples),
    }
    if SCIPY_AVAILABLE and len(pivot) >= 3:
        try:
            rep["paired_ttest_p_sdrg_less"] = float(ttest_rel(pivot[target], pivot["best_fixed"], alternative="less").pvalue)
        except Exception:
            rep["paired_ttest_p_sdrg_less"] = None
        try:
            rep["wilcoxon_p_sdrg_less"] = float(wilcoxon(pivot[target], pivot["best_fixed"], alternative="less").pvalue)
        except Exception:
            rep["wilcoxon_p_sdrg_less"] = None
    return rep, pivot.reset_index()


