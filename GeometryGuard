def run_benchmark(cfg):
    os.makedirs(cfg.out_dir, exist_ok=True)
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  SDRG-CMF v3 GeometryGuard Benchmark                               ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")
    print(json.dumps(asdict(cfg), indent=2))

    if not run_acceptance_tests(cfg):
        raise RuntimeError("Acceptance tests failed")

    benchmarks = ["sdrg_cas", "continual_memory", "abrupt_drift", "gradual_drift", "dynamical_system"]
    all_summaries, all_steps = [], []
    representative_traces, representative_regimes = None, None

    for bench in benchmarks:
        print(f"\n=== Benchmark: {bench} ===")
        T = cfg.T_main if bench == "sdrg_cas" else cfg.T_aux
        for seed in cfg.seeds:
            summary, steps, traces, F, Y, regimes = run_one(seed, bench, cfg, T=T, noise=cfg.noise)
            all_summaries.append(summary)
            all_steps.append(steps)
            if representative_traces is None and bench == "sdrg_cas":
                representative_traces, representative_regimes = traces, regimes

            p = summary.pivot(index="seed", columns="model", values="mse")
            fixed_cols = [c for c in p.columns if c.startswith("fixed_")]
            best = p[fixed_cols].min(axis=1).iloc[0]
            best_name = p[fixed_cols].idxmin(axis=1).iloc[0]
            sdrg = p["sdrg_full_v3"].iloc[0]
            gain = 100*(best-sdrg)/best
            print(f"  seed={seed} best_fixed={best_name} {best:.5f} | sdrg_full_v3={sdrg:.5f} | gain={gain:.2f}%")

    summary_df = pd.concat(all_summaries, ignore_index=True)
    step_df = pd.concat(all_steps, ignore_index=True)

    reports, paired_tables = {}, []
    for bench in benchmarks:
        rep, paired = paired_report(summary_df, bench, cfg)
        reports[bench] = rep
        paired_tables.append(paired)

    print("\n════════════════════════════════════════════════════════════════════════")
    print("FINAL STATISTICAL REPORT")
    print("════════════════════════════════════════════════════════════════════════")
    print(json.dumps(reports, indent=2))

    print("\nMean MSE leaderboard by benchmark:")
    for bench in benchmarks:
        print(f"\n[{bench}]")
        print(summary_df[summary_df.benchmark == bench].groupby("model")["mse"].mean().sort_values().to_string())

    make_plots(summary_df, paired_tables, representative_traces, representative_regimes, reports, cfg)
    zpath = save_artifacts(summary_df, step_df, paired_tables, reports, cfg)
    print("\nSaved artifacts:")
    print(f"  {cfg.out_dir}/run_summary_by_seed_model.csv")
    print(f"  {cfg.out_dir}/per_step_errors.csv")
    print(f"  {cfg.out_dir}/paired_sdrg_vs_best_fixed.csv")
    print(f"  {cfg.out_dir}/benchmark_report.json")
    print(f"  {cfg.out_dir}/RESULTS_CARD.md")
    print(f"  {zpath}")
    return summary_df, step_df, reports


