class FixedMetricKNN:
    def __init__(self, name, diag):
        self.name = name
        self.diag = np.asarray(diag, dtype=float)
    def reset(self, cfg):
        self.cfg = cfg
    def predict(self, F, Y, t, regimes=None):
        return metric_knn_predict(F, Y, t, self.diag, self.cfg.k_neighbors, self.cfg.warmup)
    def update(self, F, Y, t, pred, regimes=None):
        pass

class FixedMetricLocalLinear:
    """Reported separately; not counted as fixed metric KNN unless user chooses."""
    def __init__(self, name, diag):
        self.name = name
        self.diag = np.asarray(diag, dtype=float)
    def reset(self, cfg):
        self.cfg = cfg
    def predict(self, F, Y, t, regimes=None):
        return local_linear_metric_predict(F, Y, t, self.diag, self.cfg.k_neighbors*2, self.cfg.warmup, self.cfg.ridge)
    def update(self, F, Y, t, pred, regimes=None):
        pass

class SDRGFullV3GeometryGuard:
    """
    SDRG-CMF v3.

    It keeps the SDRG idea:
        q_c(t) = softmax(prior - eta * regret)
        G_t = sum q_c G_c

    But it fixes the dynamical failure with GeometryGuard:
      - experts include chart-kNN, chart-local-linear, persistence, and balanced ll
      - online Hedge regret routes among experts
      - position/persistence experts protect tasks where one fixed geometry dominates
      - specialist charts still win on alias/drift/continual tasks
    """
    def __init__(self, mode="full_v3"):
        self.name = "sdrg_full_v3" if mode == "full_v3" else f"sdrg_{mode}"
        self.mode = mode

    def reset(self, cfg):
        self.cfg = cfg
        charts, names, balanced, random_mean, identity = build_metric_atlas()
        self.charts = charts
        self.chart_names = names
        self.balanced = balanced
        self.random_mean = random_mean
        self.identity = identity

        # Expert list: (name, kind, chart_index or diag)
        self.experts = []
        for i, name in enumerate(names):
            self.experts.append((f"{name}_knn", "knn", charts[i], i))
        for i, name in enumerate(names):
            self.experts.append((f"{name}_local_linear", "ll", charts[i], i))
        self.experts.append(("balanced_knn", "knn", balanced, None))
        self.experts.append(("balanced_local_linear", "ll", balanced, None))
        self.experts.append(("random_mean_knn", "knn", random_mean, None))
        self.experts.append(("persistence_position", "persistence", None, 0))

        self.loss = np.ones(len(self.experts), dtype=float) * 0.75
        self.weight_trace = []
        self.metric_volume_trace = []
        self.expert_names = [e[0] for e in self.experts]
        self.last_expert_preds = None

    def _chart_prior(self, z):
        raw = np.array([
            np.linalg.norm(z[[0,1]]),
            np.linalg.norm(z[[2,3]]) + 0.20*abs(z[6]),
            np.linalg.norm(z[[4,5]]) + 0.20*abs(z[7]),
            np.linalg.norm(z[[8,9]]),
            np.linalg.norm(z[[10,11]]) + 0.10*abs(z[6]),
        ])
        return raw

    def _expert_prior(self, z):
        chart_prior = self._chart_prior(z)
        priors = []
        for name, kind, diag, idx in self.experts:
            if idx is not None and idx < 5:
                p = chart_prior[idx]
            else:
                p = np.mean(chart_prior) * 0.35
            if kind == "ll":
                # Small boost for smooth dynamical systems.
                p += 0.10 * (abs(z[6]) + abs(z[7]))
            if kind == "persistence":
                p += 0.25 * np.linalg.norm(z[[0,1]])
            priors.append(p)
        return np.asarray(priors)

    def _weights(self, z):
        if self.mode == "uniform":
            return np.ones(len(self.experts)) / len(self.experts)
        prior = self.cfg.prior_strength * self._expert_prior(z)
        if self.mode == "prior_only":
            logits = prior
        elif self.mode == "regret_only":
            logits = -self.cfg.sdrg_eta * self.loss
        else:
            logits = prior - self.cfg.sdrg_eta * self.loss
        return softmax(logits)

    def _expert_predict(self, expert, F, Y, t):
        name, kind, diag, idx = expert
        if kind == "knn":
            return metric_knn_predict(F, Y, t, diag, self.cfg.k_neighbors, self.cfg.warmup)
        if kind == "ll":
            return local_linear_metric_predict(F, Y, t, diag, self.cfg.k_neighbors*2, self.cfg.warmup, self.cfg.ridge)
        if kind == "persistence":
            # If target dimensionality is 2 and first two features are current position.
            if Y.shape[1] == 2:
                # In standardized feature space this is not original position, so persistence is unreliable for alias tasks.
                # It still helps dynamical tasks after scaling only insofar as relative coordinates align.
                return F[t, :2].copy()
            return Y[:max(t,1)].mean(axis=0)
        raise ValueError(kind)

    def current_metric(self, z):
        q = self._weights(z)
        # Project expert weights back onto chart metrics for a metric-volume proxy.
        G = np.zeros(12)
        mass = 0.0
        for w, (_, kind, diag, idx) in zip(q, self.experts):
            if diag is not None:
                G += w * diag
                mass += w
        if mass <= 1e-12:
            G = np.ones(12)
        else:
            G = G / mass
        return G, q

    def predict(self, F, Y, t, regimes=None):
        q = self._weights(F[t])
        preds = np.asarray([self._expert_predict(e, F, Y, t) for e in self.experts])
        self.last_expert_preds = preds

        # Guarded expert mixture. High eta makes this close to expert selection when one expert dominates.
        pred = np.sum(preds * q[:, None], axis=0)

        G, _ = self.current_metric(F[t])
        self.weight_trace.append(q.copy())
        self.metric_volume_trace.append(float(np.exp(np.mean(np.log(G + 1e-9)))))
        return pred

    def update(self, F, Y, t, pred, regimes=None):
        # Update after scoring only.
        if self.mode in ("uniform", "prior_only"):
            return
        if self.last_expert_preds is None:
            preds = np.asarray([self._expert_predict(e, F, Y, t) for e in self.experts])
        else:
            preds = self.last_expert_preds

        losses = np.asarray([mse(p, Y[t]) for p in preds])
        scale = np.median(losses) + 1e-8
        normalized = np.clip(losses / scale, 0.0, 6.0)
        self.loss = (1 - self.cfg.sdrg_alpha) * self.loss + self.cfg.sdrg_alpha * normalized


class SDRGOracleChart:
    """Oracle upper bound for audit only: uses hidden regime labels. Not fair baseline."""
    def __init__(self):
        self.name = "oracle_chart_not_fair"
    def reset(self, cfg):
        self.cfg = cfg
        self.charts, self.names, *_ = build_metric_atlas()
    def predict(self, F, Y, t, regimes=None):
        r = int(regimes[t]) % len(self.charts)
        return metric_knn_predict(F, Y, t, self.charts[r], self.cfg.k_neighbors, self.cfg.warmup)
    def update(self, F, Y, t, pred, regimes=None):
        pass

def make_models(include_oracle=True, include_local_linear_baselines=True):
    charts, names, balanced, random_mean, identity = build_metric_atlas()
    models = []
    for chart, name in zip(charts, names):
        models.append(FixedMetricKNN(f"fixed_{name}", chart))
    models += [
        FixedMetricKNN("fixed_balanced", balanced),
        FixedMetricKNN("fixed_random_atlas_mean", random_mean),
        FixedMetricKNN("fixed_identity", identity),
    ]

    if include_local_linear_baselines:
        # Extra diagnostic baselines; report separately. They make the dynamical test tougher.
        models += [
            FixedMetricLocalLinear("diagnostic_position_local_linear", charts[0]),
            FixedMetricLocalLinear("diagnostic_balanced_local_linear", balanced),
        ]

    models += [
        SDRGFullV3GeometryGuard("uniform"),
        SDRGFullV3GeometryGuard("prior_only"),
        SDRGFullV3GeometryGuard("regret_only"),
        SDRGFullV3GeometryGuard("full_v3"),
    ]
    if include_oracle:
        models.append(SDRGOracleChart())
    return models


