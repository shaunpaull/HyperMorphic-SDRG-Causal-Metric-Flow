def set_seed(seed: int):
    random.seed(seed)
    np.random.seed(seed)

def softmax(logits):
    z = np.asarray(logits, dtype=float)
    z = z - np.max(z)
    e = np.exp(z)
    return e / np.sum(e)

def mse(a, b):
    d = np.asarray(a) - np.asarray(b)
    return float(np.mean(d * d))

def mae(a, b):
    return float(np.mean(np.abs(np.asarray(a) - np.asarray(b))))

def rmse(x):
    return float(np.sqrt(max(0.0, x)))

def bootstrap_ci(values, n_boot=1000, seed=123):
    vals = np.asarray(values, dtype=float)
    if len(vals) == 0:
        return [None, None]
    rng = np.random.default_rng(seed)
    boots = [float(np.mean(rng.choice(vals, size=len(vals), replace=True))) for _ in range(n_boot)]
    return [float(np.percentile(boots, 2.5)), float(np.percentile(boots, 97.5))]


class PrefixStandardizer:
    """Leak-safe scaler: fit only on the warmup prefix."""
    def fit(self, X):
        self.fit_n_ = len(X)
        self.mu = X.mean(axis=0)
        self.sigma = X.std(axis=0) + 1e-6
        return self
    def transform(self, X):
        return (X - self.mu) / self.sigma


